{
  "tests": [
    {
      "name": "Auth missing fields",
      "method": "POST",
      "path": "/?action=auth",
      "body": {"login": "", "password": ""},
      "expectedStatus": 400,
      "expectedBody": {"error": "Введите логин и пароль"},
      "bodyMatcher": "partial"
    },
    {
      "name": "User info missing login",
      "method": "GET",
      "path": "/?action=user_info",
      "expectedStatus": 400,
      "expectedBody": {"error": "login parameter required"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Payments missing login",
      "method": "GET",
      "path": "/?action=payments",
      "expectedStatus": 400,
      "expectedBody": {"error": "login parameter required"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Unknown action",
      "method": "GET",
      "path": "/?action=unknown",
      "expectedStatus": 400,
      "expectedBody": {"error": "Unknown action"},
      "bodyMatcher": "partial"
    }
  ]
}